# ─────────────────────────────────────────────────────────────
# TREND CONTENT FACTORY — 환경변수 예시
# 실제 값은 .env.local (git-ignored) 또는 Supabase Vault 에만 저장.
# 시크릿을 이 파일에 절대 채우지 말 것 (예시/빈값만).
# ─────────────────────────────────────────────────────────────

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # service_role 키 (서버 전용, 절대 클라이언트 노출 금지)

# --- LLM (Claude) ---
ANTHROPIC_API_KEY=                    # 비어있으면 compose 워커는 dry-run 목업 생성기로 폴백
COMPOSE_MODEL=claude-sonnet-5         # 소재 생성 모델
REVIEW_MODEL=claude-sonnet-5          # 품질 게이트(M3, Phase 2) 모델

# --- 트렌드 소스 (선택: 없으면 해당 어댑터는 skip) ---
YOUTUBE_API_KEY=                      # YouTube Data API v3 (인기영상)
NAVER_CLIENT_ID=                      # 네이버 데이터랩 API
NAVER_CLIENT_SECRET=

# --- 알림 (실패 시 텔레그램) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 런타임 튜닝 ---
INGEST_PER_SOURCE_LIMIT=25            # 소스당 최대 수집 건수
COMPOSE_OVERSAMPLE=2.5                # 목표 대비 초안 과생성 배수 (게이트 탈락분 감안)
HTTP_TIMEOUT_MS=15000
LOG_LEVEL=info                        # debug | info | warn | error

# --- 게시 (Phase 3+, 지금은 미사용. 하드코딩 금지 상기용 자리) ---
# 토큰/계정별 시크릿은 accounts 테이블 + Vault 참조 ID로만 관리한다.
