# ─────────────────────────────────────────────────────────────
# TREND CONTENT FACTORY — 환경변수 예시
# 실제 값은 .env.local (git-ignored) 또는 Supabase Vault 에만 저장.
# 시크릿을 이 파일에 절대 채우지 말 것 (예시/빈값만).
# ─────────────────────────────────────────────────────────────

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=            # service_role 키 (서버 전용, 절대 클라이언트 노출 금지)

# --- LLM (Claude) ---
ANTHROPIC_API_KEY=                    # 비어있으면 compose 워커는 dry-run 목업 생성기로 폴백
COMPOSE_MODEL=claude-sonnet-5         # 소재 생성 모델
REVIEW_MODEL=claude-sonnet-5          # 품질 게이트(M3, Phase 2) 모델

# --- 트렌드 소스 (선택: 없으면 해당 어댑터는 skip) ---
YOUTUBE_API_KEY=                      # YouTube Data API v3 (인기영상)
NAVER_CLIENT_ID=                      # 네이버 데이터랩 API
NAVER_CLIENT_SECRET=

# --- 알림 (실패 시 텔레그램) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 런타임 튜닝 ---
INGEST_PER_SOURCE_LIMIT=25            # 소스당 최대 수집 건수
COMPOSE_OVERSAMPLE=2.5                # 목표 대비 초안 과생성 배수 (게이트 탈락분 감안)
HTTP_TIMEOUT_MS=15000
LOG_LEVEL=info                        # debug | info | warn | error

# --- 렌더 미디어 (Phase 2, 선택) ---
ELEVENLABS_API_KEY=                   # TTS 나레이션 (없으면 무음 트랙)
FAL_KEY=                              # fal.ai 대표컷 (없으면 절차적 CSS 배경)
# FFMPEG_PATH=                        # 커스텀 ffmpeg 경로 (기본 @ffmpeg-installer)
# CHROME_PATH=                        # 커스텀 chromium 경로 (기본 자동탐지)

# --- 게시 (Phase 3) — 테스트 계정 1개 ---
# ⚠️ 토큰 원문은 env 에만(커밋 금지). 실서비스는 Supabase Vault + accounts 테이블 참조.
PUBLISH_TEST_PLATFORM=                # ig | fb | tiktok | threads | x
PUBLISH_TEST_VERTICAL=                # 예: money-brief
PUBLISH_TEST_EXTERNAL_ID=            # ig_user_id / fb_page_id / tiktok open_id / threads uid / x uid
PUBLISH_TEST_ACCOUNT_ID=test-account
PUBLISH_TEST_TOKEN_ENV=PUBLISH_TEST_TOKEN  # 토큰이 담긴 env 변수명
PUBLISH_TEST_TOKEN=                   # 실제 액세스 토큰 (테스트)
PUBLISH_TEST_WARMUP_START=            # YYYY-MM-DD (워밍업 시작일; 없으면 성숙 계정)

# --- Meta 앱 (토큰 50일 주기 갱신 크론용) ---
META_APP_ID=
META_APP_SECRET=
