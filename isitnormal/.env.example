# 정상인가요 환경변수 (실제 값은 .env.local / Vercel 프로젝트 설정에 넣는다)

# 별도 등록 도메인 (플레이스홀더인 채로 색인/애드센스 제출 금지)
NEXT_PUBLIC_SITE_URL=https://isitnormal.example

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 투표자 해시 솔트 (임의의 긴 랜덤 문자열)
VOTER_SALT=

# UGC 작성 개방 (트래픽 생긴 뒤 "1"로 켠다. 기본 꺼짐)
NEXT_PUBLIC_UGC_ENABLED=

# 검색엔진 소유확인 (Search Console / 네이버 서치어드바이저에서 발급)
GOOGLE_SITE_VERIFICATION=
NAVER_SITE_VERIFICATION=

# 관리자 대시보드(/admin) 접근 토큰 (임의의 긴 랜덤 문자열, 미설정 시 /admin 비활성)
ADMIN_TOKEN=
