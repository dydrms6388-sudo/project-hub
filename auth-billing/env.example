# ============================================================
# auth-billing env.example
# 이 파일은 키 이름 목록만 제공합니다. 실제 값은 없습니다.
# 사용법: 이 파일을 .env.local 로 복사 후 사용자 본인이 값 입력
# .env.local 은 반드시 .gitignore 에 추가할 것
# ============================================================

# --- 허브 기본 ---
NEXT_PUBLIC_SITE_URL=PLACEHOLDER_YOUR_HUB_URL
# 예: https://tomatoeggcat.com

# --- Clerk (Auth) ---
# https://clerk.com 에서 앱 생성 후 발급 (사용자 직접)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=PLACEHOLDER_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=PLACEHOLDER_CLERK_SECRET_KEY
NEXT_PUBLIC_CLERK_SIGN_IN_URL=PLACEHOLDER_e.g./sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=PLACEHOLDER_e.g./sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=PLACEHOLDER_e.g./dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=PLACEHOLDER_e.g./dashboard

# --- Supabase (DB) ---
# https://supabase.com 에서 프로젝트 생성 후 발급 (사용자 직접)
NEXT_PUBLIC_SUPABASE_URL=PLACEHOLDER_SUPABASE_PROJECT_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=PLACEHOLDER_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=PLACEHOLDER_SUPABASE_SERVICE_ROLE_KEY

# --- JWT (자체 발급 방식 사용 시 Clerk 대신) ---
JWT_SECRET=PLACEHOLDER_STRONG_RANDOM_SECRET_MIN_32_CHARS

# --- Stripe (글로벌 결제) ---
# https://dashboard.stripe.com 에서 발급 (사용자 직접)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=PLACEHOLDER_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=PLACEHOLDER_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_STRIPE_WEBHOOK_SIGNING_SECRET
# 구독 상품 Price ID (Stripe 대시보드에서 생성 후 복사)
STRIPE_PRO_MONTHLY_PRICE_ID=PLACEHOLDER_price_xxxxx
STRIPE_PRO_YEARLY_PRICE_ID=PLACEHOLDER_price_xxxxx
STRIPE_CREDITS_10_PRICE_ID=PLACEHOLDER_price_xxxxx

# --- 토스페이먼츠 (한국 결제) ---
# https://developers.tosspayments.com 에서 상점 생성 후 발급 (사용자 직접)
NEXT_PUBLIC_TOSS_CLIENT_KEY=PLACEHOLDER_TOSS_CLIENT_KEY
TOSS_SECRET_KEY=PLACEHOLDER_TOSS_SECRET_KEY

# --- 카카오 OAuth (소셜 로그인, Clerk 내 설정 시 불필요) ---
# https://developers.kakao.com 에서 앱 생성 후 발급 (사용자 직접)
KAKAO_CLIENT_ID=PLACEHOLDER_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=PLACEHOLDER_KAKAO_CLIENT_SECRET

# --- Google OAuth (소셜 로그인, Clerk 내 설정 시 불필요) ---
# https://console.cloud.google.com 에서 OAuth 앱 생성 후 발급 (사용자 직접)
GOOGLE_CLIENT_ID=PLACEHOLDER_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=PLACEHOLDER_GOOGLE_OAUTH_CLIENT_SECRET

# --- Upstash Redis (세션 캐시, 선택) ---
# https://upstash.com 에서 DB 생성 후 발급 (사용자 직접)
UPSTASH_REDIS_REST_URL=PLACEHOLDER_UPSTASH_REST_URL
UPSTASH_REDIS_REST_TOKEN=PLACEHOLDER_UPSTASH_REST_TOKEN

# --- Resend (이메일 알림, 선택) ---
# https://resend.com 에서 API 키 발급 (사용자 직접)
RESEND_API_KEY=PLACEHOLDER_RESEND_API_KEY
RESEND_FROM_EMAIL=PLACEHOLDER_noreply@tomatoeggcat.com
