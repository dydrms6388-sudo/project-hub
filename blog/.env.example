# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...        # 공개 읽기(anon)
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # 발행 쓰기(service_role) — 서버 전용, 절대 노출 금지

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Vercel Cron 인증. 이 값이 설정되면 Vercel 이 크론 요청에
# Authorization: Bearer ${CRON_SECRET} 헤더를 자동으로 붙인다.
CRON_SECRET=change-me-to-a-long-random-string
