# ============================================================
# auth-hub .env.example
# 키 이름(placeholder)만 제공합니다. 실제 값은 절대 커밋하지 마세요.
# 사용법: cp .env.example .env.local  후 각 값을 사용자 본인이 채웁니다.
# .env / .env.local 은 .gitignore 에 포함되어 있습니다.
# ============================================================

# --- 허브 기본 ---
# Auth.js v5 가 콜백 URL 을 만들 때 사용. 로컬: http://localhost:3000
AUTH_URL=PLACEHOLDER_e.g._https://tomatoeggcat.com
NEXT_PUBLIC_SITE_URL=PLACEHOLDER_e.g._https://tomatoeggcat.com

# --- Auth.js (NextAuth v5) ---
# 32자 이상 랜덤. 생성: `openssl rand -base64 32`
AUTH_SECRET=PLACEHOLDER_STRONG_RANDOM_SECRET_MIN_32_CHARS
# 서브도메인 간 쿠키 공유가 필요하면 설정 (예: .tomatoeggcat.com). 단일 도메인이면 비워둠.
AUTH_COOKIE_DOMAIN=

# --- Google OAuth ---
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID
# 승인된 리디렉션 URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=PLACEHOLDER_GOOGLE_OAUTH_CLIENT_ID
AUTH_GOOGLE_SECRET=PLACEHOLDER_GOOGLE_OAUTH_CLIENT_SECRET

# --- 카카오 OAuth ---
# https://developers.kakao.com → 내 애플리케이션 → 앱 키(REST API 키) + 보안(Client Secret)
# Redirect URI: {AUTH_URL}/api/auth/callback/kakao
KAKAO_CLIENT_ID=PLACEHOLDER_KAKAO_REST_API_KEY
KAKAO_CLIENT_SECRET=PLACEHOLDER_KAKAO_CLIENT_SECRET

# --- 네이버 OAuth ---
# https://developers.naver.com → 애플리케이션 등록 → Client ID / Client Secret
# Callback URL: {AUTH_URL}/api/auth/callback/naver
NAVER_CLIENT_ID=PLACEHOLDER_NAVER_CLIENT_ID
NAVER_CLIENT_SECRET=PLACEHOLDER_NAVER_CLIENT_SECRET

# --- 데이터베이스 (Neon Postgres) ---
# https://neon.tech 에서 프로젝트 생성 후 연결 문자열 복사.
# DATABASE_URL: 앱 런타임용 (pooled, ?sslmode=require&pgbouncer=true 권장)
# DIRECT_URL:   prisma migrate 용 (direct, non-pooled)
DATABASE_URL=PLACEHOLDER_postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
DIRECT_URL=PLACEHOLDER_postgresql://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require

# --- Stripe (글로벌 결제) ---
# https://dashboard.stripe.com → 개발자 → API 키 / 웹훅
STRIPE_SECRET_KEY=PLACEHOLDER_sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=PLACEHOLDER_whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=PLACEHOLDER_pk_live_or_test_xxx
# 대시보드 → 상품 에서 만든 Price ID
STRIPE_PRICE_PRO_MONTHLY=PLACEHOLDER_price_xxx
STRIPE_PRICE_PRO_YEARLY=PLACEHOLDER_price_xxx
STRIPE_PRICE_CREDITS_10=PLACEHOLDER_price_xxx

# --- 토스페이먼츠 (한국 결제) ---
# https://developers.tosspayments.com → 내 개발정보 → API 키
TOSS_SECRET_KEY=PLACEHOLDER_test_sk_or_live_sk_xxx
NEXT_PUBLIC_TOSS_CLIENT_KEY=PLACEHOLDER_test_ck_or_live_ck_xxx
# 토스 웹훅(가상계좌 입금 등) 검증용. 개발자센터 → 웹훅 에서 설정.
TOSS_WEBHOOK_SECRET=PLACEHOLDER_TOSS_WEBHOOK_SECRET

# --- 네이티브(앱) 베어러 토큰 ---
# React Native/Expo 앱용 JWT 서명 시크릿. 미설정 시 AUTH_SECRET 로 폴백.
# 생성: `openssl rand -base64 32`
MOBILE_JWT_SECRET=PLACEHOLDER_STRONG_RANDOM_SECRET_MIN_32_CHARS
# 네이티브 로그인 복귀 시 허용할 앱 스킴(쉼표구분). 오픈 리다이렉트 방지용 화이트리스트.
# 예: nyangstat,beautytimeline,popupchinese,vocalroutine,lumora,meetintravel
ALLOWED_MOBILE_SCHEMES=PLACEHOLDER_app1,app2

# --- 인앱결제(IAP) 영수증 검증 ---
# Apple: App Store Connect → 앱 → 앱 정보 → 공유 비밀키(앱 전용/공유)
APPLE_SHARED_SECRET=PLACEHOLDER_APPLE_APP_SHARED_SECRET
# Google Play: Play Console → 설정 → API 액세스 → 서비스 계정 JSON(한 줄로 저장)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=PLACEHOLDER_GOOGLE_SERVICE_ACCOUNT_JSON_ONE_LINE
GOOGLE_PLAY_PACKAGE_NAME=PLACEHOLDER_com.yourcompany.app

# --- 마이크로서비스 ↔ 허브 공유 ---
# 각 웹 마이크로서비스가 허브 세션 JWT 를 stateless 검증하려면 동일한 AUTH_SECRET 과
# (서브도메인/apex 쿠키 공유 시) 동일한 AUTH_COOKIE_DOMAIN 을 가져야 한다.
# 각 앱(.env)에는 NEXT_PUBLIC_HUB_URL 로 이 허브 주소를 넣는다.
