{
  "buildCommand": "node gen-pages.mjs",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/dalian-weekend",
      "destination": "https://dydrms-dalian.vercel.app/dalian-weekend"
    },
    {
      "source": "/dalian-weekend/:path*",
      "destination": "https://dydrms-dalian.vercel.app/dalian-weekend/:path*"
    }
  ],
  "headers": [
    {
      "source": "/dalian-weekend",
      "headers": [
        {
          "key": "Link",
          "value": "<https://tomatoeggcat.com/dalian-weekend/>; rel=\"canonical\""
        }
      ]
    }
  ]
}
